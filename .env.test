# Test Environment Variables
# Copy this file to .env.test and adjust as needed

# MongoDB
MONGODB_URI=mongodb://localhost:27017/finedge-test

# JWT Secrets (use long, random strings in production)
JWT_SECRET=test-jwt-secret-key-minimum-32-characters-long-for-security
JWT_REFRESH_SECRET=test-jwt-refresh-secret-key-minimum-32-characters-long

# Server
PORT=5000
NODE_ENV=test

# API Keys (if using external services)
# GOOGLE_API_KEY=your-key-here
# OPENAI_API_KEY=your-key-here
